# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=xcel-cms

# ── Payload CMS ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_RANDOM_SECRET

# ── MinIO (S3 media storage) ─────────────────────────────────────
S3_ACCESS_KEY=CHANGE_ME_MINIO_USER
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET=xcel-media
S3_REGION=us-east-1

# ── Site URL ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://xcellocksmith.com

# ── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ── WAHA (WhatsApp) ──────────────────────────────────────────────
# Set a strong API key to protect the WAHA dashboard
WAHA_API_KEY=CHANGE_ME_WAHA_KEY
