# =============================================================================
# Xcel Locksmith CMS — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Connection string for the PostgreSQL instance.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xcel-cms

# -----------------------------------------------------------------------------
# Payload CMS
# -----------------------------------------------------------------------------
# Secret used to sign JWT tokens and encrypt session data.
# Generate a strong random string (e.g. openssl rand -hex 32).
PAYLOAD_SECRET=change-me-to-a-random-secret

# -----------------------------------------------------------------------------
# S3-Compatible Storage (MinIO)
# -----------------------------------------------------------------------------
# Endpoint URL for the MinIO (or any S3-compatible) server.
S3_ENDPOINT=http://localhost:9000

# Access credentials for the S3 bucket.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Bucket name where media files are stored.
S3_BUCKET=xcel-media

# AWS region identifier (MinIO ignores this, but the SDK requires it).
S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Site URL
# -----------------------------------------------------------------------------
# Public base URL used for sitemap generation and canonical links.
NEXT_PUBLIC_SITE_URL=https://xcellocksmith.com

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# API key for the Resend transactional email service.
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
